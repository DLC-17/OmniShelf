# OmniShelf configuration (project_spec.md §1.3). Copy to .env and fill in.

# HTTP listen port
OMNISHELF_PORT=8080

# SQLite location (mapped to /mnt/media-tracker/data on TrueNAS)
OMNISHELF_DATA_DIR=/data

# Cached image root (mapped to /mnt/media-tracker/images on TrueNAS)
OMNISHELF_IMAGES_DIR=/images

# HMAC signing key for JWTs — REQUIRED; the app refuses to start if it is
# unset, shorter than 32 characters, or left at this placeholder.
# Generate one with: openssl rand -hex 32
OMNISHELF_JWT_SECRET=change-me-to-a-long-random-string

# TMDB v3 API key (required for the TV and movie modules)
TMDB_API_KEY=your-tmdb-api-key

# Contact email injected into the OpenLibrary User-Agent (required for the book module)
OMNISHELF_CONTACT_EMAIL=you@example.com

# ScanDex credentials for game barcode lookups (optional: games module
# reports "not configured" without them)
SCANDEX_USER_ID=your-scandex-user-id

SCANDEX_ACCESS_TOKEN=your-scandex-access-token

# IGDB (Twitch developer) credentials for game covers/summaries (optional)
IGDB_CLIENT_ID=your-igdb-client-id

IGDB_CLIENT_SECRET=your-igdb-client-secret

# Google Cloud service-account JSON file for Vision OCR card scanning
# (optional: cards module reports "not configured" without it)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Pokémon TCG API key (optional: api.pokemontcg.io works keyless at lower
# rate limits)
POKEMONTCG_API_KEY=your-pokemontcg-api-key

# OmniShelf configuration (project_spec.md §1.3). Copy to .env and fill in.

# HTTP listen port
OMNISHELF_PORT=8080

# SQLite location (mapped to /mnt/media-tracker/data on TrueNAS)
OMNISHELF_DATA_DIR=/data

# Cached image root (mapped to /mnt/media-tracker/images on TrueNAS)
OMNISHELF_IMAGES_DIR=/images

# HMAC signing key for JWTs — REQUIRED; the app refuses to start if unset.
# Generate one with: openssl rand -hex 32
OMNISHELF_JWT_SECRET=change-me-to-a-long-random-string

# TMDB v3 API key (required for the TV module)
TMDB_API_KEY=your-tmdb-api-key

# Contact email injected into the OpenLibrary User-Agent (required for the book module)
OMNISHELF_CONTACT_EMAIL=you@example.com
